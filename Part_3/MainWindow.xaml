<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Awareness Chatbot"
        Height="750" Width="980"
        MinHeight="620" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.Resources>

        <!-- Start Button -->
        <Style x:Key="StartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0099CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007AA3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send Button -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="18,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0099CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007AA3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Action Button (toolbar) -->
        <Style x:Key="QuickButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1C2333"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#00BFFF"/>
                                <Setter Property="BorderBrush" Value="#00BFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D1117"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Name Input -->
        <Style x:Key="NameBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#00BFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007AA3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- ══════════════════════════════════════
             PAGE 1 — WELCOME (light)
        ══════════════════════════════════════ -->
        <Grid x:Name="WelcomePage" Background="White" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                        Width="420" Margin="0,180,0,0" Grid.RowSpan="2">

                <Image x:Name="WelcomeLogo"
                       Width="160" Height="160"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="pack://application:,,,/cyberbot_logo.png"/>

                <TextBlock Text="CYBER BOT"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#00BFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Cybersecurity Awareness Assistant"
                           FontSize="13" Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- Feature badges -->
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Background="#EBF8FF" CornerRadius="10" Padding="8,3" Margin="3,2">
                        <TextBlock Text="✅ Task Assistant" FontSize="11" Foreground="#0099CC"/>
                    </Border>
                    <Border Background="#F0FFF0" CornerRadius="10" Padding="8,3" Margin="3,2">
                        <TextBlock Text="🎮 Quiz Game" FontSize="11" Foreground="#2E7D32"/>
                    </Border>
                    <Border Background="#FFF8E7" CornerRadius="10" Padding="8,3" Margin="3,2">
                        <TextBlock Text="🧠 NLP Simulation" FontSize="11" Foreground="#E65100"/>
                    </Border>
                    <Border Background="#FFF0F5" CornerRadius="10" Padding="8,3" Margin="3,2">
                        <TextBlock Text="📋 Activity Log" FontSize="11" Foreground="#880E4F"/>
                    </Border>
                </WrapPanel>

                <Border Height="1" Background="#E0E0E0" Margin="0,0,0,24"/>

                <TextBlock Text="Welcome! Before we begin, what's your name?"
                           FontSize="15" Foreground="#444444"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBox x:Name="NameInputBox"
                         Style="{StaticResource NameBoxStyle}"
                         KeyDown="NameInputBox_KeyDown"/>

                <TextBlock Text="Press Enter to start chatting"
                           FontSize="11" Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#F5F5F5" VerticalAlignment="Bottom" Padding="0,12">
                <TextBlock Text="Stay safe online — CyberBot is here to help"
                           FontSize="12" Foreground="#AAAAAA"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════
             PAGE 2 — CHAT (dark)
        ══════════════════════════════════════ -->
        <Grid x:Name="ChatPage" Background="#0D1117" Visibility="Collapsed">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Quick-action toolbar -->
                <RowDefinition Height="*"/>
                <!-- Chat display -->
                <RowDefinition Height="Auto"/>
                <!-- Status bar -->
                <RowDefinition Height="Auto"/>
                <!-- Input area -->
            </Grid.RowDefinitions>

            <!-- HEADER ─────────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#161B22"
                    BorderBrush="#21262D"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Image x:Name="HeaderLogo"
                           Grid.Column="0"
                           Width="44" Height="44"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="CyberBot"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#00BFFF"/>
                        <TextBlock x:Name="ChatSubtitle"
                                   Text="Cybersecurity Awareness Assistant"
                                   FontSize="11" Foreground="#8B949E"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#3FB950"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Online" FontSize="11" Foreground="#3FB950"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- QUICK-ACTION TOOLBAR ─────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    Background="#161B22"
                    BorderBrush="#21262D"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Quick:" Foreground="#8B949E" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <Button x:Name="BtnAddTask"
                            Content="✅ Add Task"
                            Style="{StaticResource QuickButtonStyle}"
                            Click="BtnAddTask_Click"
                            ToolTip="Add a cybersecurity task"/>

                    <Button x:Name="BtnShowTasks"
                            Content="📋 My Tasks"
                            Style="{StaticResource QuickButtonStyle}"
                            Click="BtnShowTasks_Click"
                            ToolTip="View all your tasks"/>

                    <Button x:Name="BtnStartQuiz"
                            Content="🎮 Start Quiz"
                            Style="{StaticResource QuickButtonStyle}"
                            Click="BtnStartQuiz_Click"
                            ToolTip="Test your cybersecurity knowledge"/>

                    <Button x:Name="BtnShowLog"
                            Content="📊 Activity Log"
                            Style="{StaticResource QuickButtonStyle}"
                            Click="BtnShowLog_Click"
                            ToolTip="View recent bot activity"/>

                    <Button x:Name="BtnHelp"
                            Content="❓ Help"
                            Style="{StaticResource QuickButtonStyle}"
                            Click="BtnHelp_Click"
                            ToolTip="See all commands"/>
                </StackPanel>
            </Border>

            <!-- CHAT DISPLAY ──────────────────────────────────────────────────── -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="2"
                          Background="#0D1117"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,8">
                <StackPanel x:Name="ChatPanel" Margin="16,0"/>
            </ScrollViewer>

            <!-- STATUS BAR ────────────────────────────────────────────────────── -->
            <Border Grid.Row="3"
                    Background="#161B22"
                    BorderBrush="#21262D"
                    BorderThickness="0,1,0,0"
                    Padding="16,5">
                <TextBlock x:Name="StatusText"
                           Text="Type a message and press Enter or click Send"
                           FontSize="11" Foreground="#8B949E"/>
            </Border>

            <!-- INPUT AREA ────────────────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Background="#161B22"
                    BorderBrush="#21262D"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInputBox"
                             Grid.Column="0"
                             Height="44"
                             Background="#1C2333"
                             Foreground="#FFFFFF"
                             CaretBrush="#00BFFF"
                             SelectionBrush="#00BFFF"
                             BorderBrush="#30363D"
                             BorderThickness="1"
                             FontSize="14"
                             Padding="12,10"
                             VerticalContentAlignment="Center"
                             KeyDown="UserInputBox_KeyDown"
                             TextChanged="UserInputBox_TextChanged"/>

                    <Button x:Name="SendButton"
                            Grid.Column="2"
                            Content="Send  ➤"
                            Style="{StaticResource SendButtonStyle}"
                            Height="44" Width="100"
                            Click="SendButton_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
